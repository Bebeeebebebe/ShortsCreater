
    <Window x:Class="ShortsMaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ShortsMaker"
        Background="#1F1F1F"
        WindowStartupLocation="CenterScreen"
        Width="1400"
        Height="800"
        xmlns:local="clr-namespace:ShortsMaker">

    <!-- ===================== РЕСУРСЫ ===================== -->
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:InverseBooleanConverter x:Key="BoolToVisibilityInverse"/>
        <local:FileNameConverter x:Key="FileNameConverter"/>
        <local:StringNotEmptyConverter x:Key="StringNotEmptyConverter"/>
        <!-- ===== Кнопки ===== -->
        <BlurEffect x:Key="Blur10" Radius="10"/>

        <Style x:Key="FrostedButtonBase" TargetType="Button">
            <Setter Property="Padding" Value="12 6"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Bg"
                            CornerRadius="14"
                            Background="{TemplateBinding Background}"
                            Effect="{StaticResource Blur10}"
                            Opacity="0.9"/>
                            <Border CornerRadius="14"
                            Background="#4FFFFFFF"/>
                            <ContentPresenter HorizontalAlignment="Center"
          VerticalAlignment="Center"
          TextElement.FontWeight="SemiBold"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg"
                                Property="Opacity"
                                Value="1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg"
                                Property="Opacity"
                                Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FrostedButtonLight"
       TargetType="Button"
       BasedOn="{StaticResource FrostedButtonBase}">
            <Setter Property="Background" Value="#60FFFFFF"/>
            <Setter Property="Foreground" Value="#222"/>
        </Style>

        <Style x:Key="FrostedButtonDark"
       TargetType="Button"
       BasedOn="{StaticResource FrostedButtonBase}">
            <Setter Property="Background" Value="#60000000"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="WatermarkTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost"/>
                            <TextBlock Text="{TemplateBinding Tag}"
                       Foreground="#777777"
                       Margin="5,3"
                       IsHitTestVisible="False"
                       Visibility="Collapsed"
                       x:Name="Watermark"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Watermark"
                        Property="Visibility"
                        Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <DataTemplate x:Key="UploadAccountManagerTemplate">
            <Expander
        IsExpanded="True"
        Margin="0 0 0 8">

                <!-- ===== HEADER ===== -->
                <Expander.Header>
                    <TextBlock
        FontWeight="SemiBold"
        Foreground="Black"
        VerticalAlignment="Center">

                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} {1}">
                                <!-- Имя аккаунта -->
                                <Binding Path="Name" TargetNullValue=""/>

                                <!-- Платформа -->
                                <Binding Path="Platform"/>
                            </MultiBinding>
                        </TextBlock.Text>

                    </TextBlock>
                </Expander.Header>

                <!-- ===== BODY ===== -->
                <Border
            Background="#FFFFFF"
            CornerRadius="8"
            Padding="10"
            Margin="0 6 0 0">

                    <StackPanel>

                        <!-- Платформа -->
                        <TextBlock Text="Платформа"
                           FontWeight="SemiBold"
                           Margin="0 0 0 2"/>
                        <ComboBox
                    ItemsSource="{Binding Platforms}"
                    SelectedItem="{Binding Platform}"/>

                        <!-- Имя аккаунта -->
                        <TextBlock Text="Имя аккаунта"
                           FontWeight="SemiBold"
                           Margin="0 6 0 2"/>
                        <TextBox
                        Text="{Binding Name}"
                        Style="{StaticResource WatermarkTextBox}"
                        Foreground="Black"
                        Tag="Например: main_tiktok"/>
                        <!-- Авторизация -->
                        <Button
                    Content="🔐 Авторизоваться"
                    Margin="0 8 0 0"
                    Height="30"
                    IsEnabled="{Binding Name, Converter={StaticResource StringNotEmptyConverter}}"
                    Click="AuthorizeAccount_Click"/>
                    </StackPanel>
                </Border>

            </Expander>
        </DataTemplate>

        <DataTemplate x:Key="ImageStyleTemplate">
            <Border Background="#252525"
            CornerRadius="6"
            Padding="10"
            Margin="0 5 0 0"
            TextElement.Foreground="White">

                <StackPanel>

                    <!-- Файл -->
                    <TextBlock Text="Изображение / Видео"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox Text="{Binding Style.FilePath}"
                         IsReadOnly="True"
                         Width="240"/>
                        <Button Content="Добавить"
                        Margin="6 0 0 0"
                        Command="{Binding Style.PickImageCommand}"/>
                    </StackPanel>
                    <!-- Прозрачность -->
                    <TextBlock Text="Прозрачность"/>
                    <TextBox Text="{Binding Style.Opacity}"/>

                    <!-- Время -->
                    <TextBlock Text="Начало (мс)"/>
                    <TextBox Text="{Binding Style.StartMs}"/>

                    <TextBlock Text="Конец (мс)"/>
                    <TextBox Text="{Binding Style.EndMs}"/>

                    <!-- Loop -->
                    <Grid Margin="0 4 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Зацикливать"
               Foreground="White"
               VerticalAlignment="Center"
               Margin="0,0,8,0"/>

                        <CheckBox Grid.Column="1"
              IsChecked="{Binding Style.Loop}"
              VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Масштаб -->
                    <TextBlock Text="Масштаб"/>
                    <TextBox Text="{Binding Style.Scale}"/>

                    <!-- Позиция -->
                    <TextBlock Text="Якорь"/>
                    <ComboBox ItemsSource="{Binding Style.Anchors}"
                         SelectedItem="{Binding Style.Anchor}"/>

                    <TextBlock Text="Смещение X"/>
                    <TextBox Text="{Binding Style.OffsetX}"/>

                    <TextBlock Text="Смещение Y"/>
                    <TextBox Text="{Binding Style.OffsetY}"/>

                    <!-- Fade -->
                    <TextBlock Text="Fade In (мс)"/>
                    <TextBox Text="{Binding Style.FadeIn}"/>

                    <TextBlock Text="Fade Out (мс)"/>
                    <TextBox Text="{Binding Style.FadeOut}"/>

                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SubtitleStyleTemplate">
            <Border Background="#252525"
            CornerRadius="6"
            Padding="10"
            Margin="0 5 0 0"
            TextElement.Foreground="White"
            TextElement.FontWeight="SemiBold">

                <Border.Resources>
                    <Style TargetType="CheckBox">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                </Border.Resources>

                <StackPanel>

                    <!-- Шрифт -->
                    <TextBlock Text="Шрифт"/>
                    <ComboBox ItemsSource="{Binding Style.Fonts}"
                      SelectedItem="{Binding Style.Font}"/>

                    <!-- Размер -->
                    <TextBlock Text="Размер"/>
                    <TextBox Text="{Binding Style.FontSize}"/>

                    <!-- Начертание -->
                    <CheckBox Content="Жирный" IsChecked="{Binding Style.Bold}"/>
                    <CheckBox Content="Курсив" IsChecked="{Binding Style.Italic}"/>

                    <!-- Цвет текста -->
                    <TextBlock Text="Цвет текста"/>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="120"
                        Height="24"
                        Background="{Binding Style.PrimaryColorBrush}"
                        BorderBrush="White"
                        BorderThickness="1"
                        CornerRadius="3"/>
                        <Button Content="..."
                        Margin="5 0 0 0"
                        Command="{Binding Style.PickPrimaryColorCommand}"/>
                    </StackPanel>

                    <!-- Цвет обводки -->
                    <TextBlock Text="Цвет обводки"/>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="120"
                        Height="24"
                        Background="{Binding Style.OutlineColorBrush}"
                        BorderBrush="White"
                        BorderThickness="1"
                        CornerRadius="3"/>
                        <Button Content="..."
                        Margin="5 0 0 0"
                        Command="{Binding Style.PickOutlineColorCommand}"/>
                    </StackPanel>

                    <!-- Обводка -->
                    <TextBlock Text="Толщина обводки"/>
                    <TextBox Text="{Binding Style.OutlineWidth}"/>

                    <!-- Тень -->
                    <TextBlock Text="Тень"/>
                    <TextBox Text="{Binding Style.ShadowWidth}"/>

                    <!-- Выравнивание -->
                    <TextBlock Text="Выравнивание"/>
                    <ComboBox ItemsSource="{Binding Style.Alignments}"
                      SelectedItem="{Binding Style.Alignment}"/>

                    <!-- Отступы -->
                    <TextBlock Text="Отступ снизу"/>
                    <TextBox Text="{Binding Style.MarginV}"/>

                    <TextBlock Text="Отступ слева"/>
                    <TextBox Text="{Binding Style.MarginL}"/>

                    <TextBlock Text="Отступ справа"/>
                    <TextBox Text="{Binding Style.MarginR}"/>

                    <!-- Появление -->
                    <TextBlock Text="Fade In (мс)"/>
                    <TextBox Text="{Binding Style.FadeIn}"/>

                    <TextBlock Text="Fade Out (мс)"/>
                    <TextBox Text="{Binding Style.FadeOut}"/>

                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="UploadResourceStyleTemplate">
            <Border Background="#252525"
            CornerRadius="6"
            Padding="10"
            Margin="0 5 0 0"
            TextElement.Foreground="White">

                <StackPanel>
                    <!-- Платформа -->
                    <TextBlock Text="Платформа" Margin="0 0 0 4"/>
                    <ComboBox
    ItemsSource="{Binding Style.Platforms}"
    SelectedItem="{Binding Style.Platform}"/>

                    <!-- Тип видео -->
                    <TextBlock Text="Тип видео" Margin="0 6 0 0"/>
                    <ComboBox ItemsSource="{Binding Style.VideoTypes}"
                      SelectedItem="{Binding Style.VideoType}"/>

                    <Expander IsExpanded="True"
          Margin="0 6 0 0">

                        <!-- ===== HEADER ===== -->
                        <Expander.Header>
                            <TextBlock Text="Аккаунты"
                   FontWeight="SemiBold"
                   Foreground="White"/>
                        </Expander.Header>

                        <!-- ===== BODY ===== -->
                        <StackPanel Margin="0 6 0 0">


                            <!-- Список аккаунтов -->
                            <ItemsControl ItemsSource="{Binding Style.Accounts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox
                IsChecked="{Binding IsSelected}"
                Foreground="White"
                FontWeight="SemiBold"
                Content="{Binding DisplayName}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>

                    </Expander>

                    <!-- Описание -->
                    <TextBlock Text="Описание" Margin="0 6 0 0"/>
                    <TextBox Text="{Binding Style.Description}"/>

                    <!-- Хештеги -->
                    <TextBlock Text="Хештеги" Margin="0 6 0 0"/>
                    <TextBox Text="{Binding Style.Hashtags}"/>

                    <!-- Звук -->
                    <TextBlock Text="Звук автор" Margin="0 6 0 0"/>
                    <TextBox Text="{Binding Style.SoundAuthor, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Звук название" Margin="0 6 0 0"/>
                    <TextBox Text="{Binding Style.SoundTitle, UpdateSourceTrigger=PropertyChanged}"/>
                    <!-- Кнопка Выгрузить -->
                    <Button Content="Выгрузить"
                    Style="{StaticResource FrostedButtonLight}"
                    HorizontalAlignment="Center"
                    Margin="0 15 0 15"
                    Width="220"
                    Height="50"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Click="StartMultiPost_Click"
                    CommandParameter="{Binding}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <local:SectionContentTemplateSelector
    x:Key="SectionTemplateSelector"
    SubtitleTemplate="{StaticResource SubtitleStyleTemplate}"
    ImageTemplate="{StaticResource ImageStyleTemplate}"
    UploadResourceTemplate="{StaticResource UploadResourceStyleTemplate}"/>

        <DataTemplate x:Key="SectionTemplate">
            <Expander Margin="0 0 0 6">

                <!-- HEADER -->
                <Expander.Header>
                    <DockPanel LastChildFill="True">
                        <CheckBox Margin="0 0 8 0"
                          IsChecked="{Binding IsEnabled}"
                          VerticalAlignment="Center"/>
                        <Grid VerticalAlignment="Center">
                            <TextBlock
    Text="{Binding Title}"
    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityInverse}}"
    MouseRightButtonDown="Title_RightClick">

                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>

                                        <Style.Triggers>
                                            <!-- ✅ enum, а не строка -->
                                            <DataTrigger
                    Binding="{Binding SectionType}"
                    Value="{x:Static local:SectionType.Upload}">
                                                <Setter Property="Foreground" Value="Black"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>

                            </TextBlock>
                            <TextBox Text="{Binding Title, Mode=TwoWay}"
                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                             LostFocus="TitleEdit_LostFocus"
                             KeyDown="TitleEdit_KeyDown"
                             MinWidth="120"/>
                        </Grid>
                        <Button DockPanel.Dock="Right"
                        Width="28" Height="28"
                        Margin="6 0 0 0"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="DeleteSection_Click">
                            <Image Source="images/trash.png" Width="32" Height="32"/>
                        </Button>
                    </DockPanel>
                </Expander.Header>

                <!-- BODY -->
                <Border Background="#1F1F1F" CornerRadius="6" Padding="10" Margin="0 5 0 0">
                    <StackPanel>
                        <TextBlock Text="{Binding Description}"
                           Foreground="#AAAAAA"
                           FontSize="12"
                           Margin="0 0 0 8"/>
                        <!-- Слот для расширения -->
                        <ContentPresenter
        Content="{Binding}"
        ContentTemplateSelector="{StaticResource SectionTemplateSelector}"/>
                    </StackPanel>
                </Border>

            </Expander>

            <!-- Triggers для SubtitleSection -->

        </DataTemplate>



        

        <Style x:Key="FormatTreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Black"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFFFC0CB"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>


        
    </Window.Resources>

    <!-- ===================== ОСНОВНАЯ СЕТКА ===================== -->
    <Grid Margin="20" x:Name="MainScreen">
        <Grid>

            <!-- ===== ВЫДВИЖНОЕ МЕНЮ ===== -->
            <Grid x:Name="SideMenu"
          Width="220"
          HorizontalAlignment="Left"
          Background="#252525"
          Margin="-288,0,0,0"
          Panel.ZIndex="10"
          MouseLeave="SideMenu_MouseLeave">

                <StackPanel Margin="20,60,20,20">

                    <Button x:Name="EditorBtn"
                    Content="🎬 Редактор видео"
                    Height="40"
                    Margin="0 0 0 10"
                    Click="EditorBtn_Click"
                    Style="{StaticResource FrostedButtonDark}"/>

                    <Button x:Name="CreateBtn"
                    Content="🧩 Создание видео"
                    Height="40"
                    Margin="0 0 0 10"
                    Click="CreateBtn_Click"
                    Style="{StaticResource FrostedButtonDark}"/>

                    <Button x:Name="SendBtn"
                    Content=" 🌐 Запостить видео"
                    Height="40"
                    Margin="0 0 0 10"
                    Click="SendBtn_Click"
                    Style="{StaticResource FrostedButtonDark}"/>

                    <Button Content="❌ Закрыть"
                    Height="36"
                    Click="Exit_Click"
                    Style="{StaticResource FrostedButtonLight}"/>
                </StackPanel>
            </Grid>

            <!-- ===== КРУЖОК-ТРИГГЕР ===== -->
            <Border x:Name="MenuTrigger"
            Width="36"
            Height="36"
            CornerRadius="18"
            Background="#3A3A3A"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Panel.ZIndex="11"
            MouseEnter="MenuTrigger_MouseEnter">

                <TextBlock Text="☰"
                   Foreground="White"
                   FontSize="18"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" RenderTransformOrigin="0.129,0.418"/>
            </Border>

            <!-- ===== ЭКРАН: РЕДАКТОР ВИДЕО ===== -->
            <Grid x:Name="EditorScreen"
          Margin="20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="500"/>
                </Grid.ColumnDefinitions>

                <!-- ===================== ЛЕВАЯ ПАНЕЛЬ ===================== -->
                <Border Background="#2A2A2A"
        CornerRadius="10"
        Padding="20"
        Margin="0 0 20 0">

                    <StackPanel>

                        <TextBlock Text="Список и форматы видео"
                   Foreground="White"
                   FontSize="16"
                   Margin="0 0 0 10"/>

                        <!-- ===== ФОРМАТЫ ===== -->
                        <Border Background="#EEEEEE"
                CornerRadius="10"
                Padding="10"
                Height="230"
                Margin="0 0 0 10">

                            <TreeView x:Name="FormatsTreeView"
  SelectedItemChanged="FormatsTreeView_SelectedItemChanged"
  ItemContainerStyle="{StaticResource FormatTreeViewItemStyle}"
  Background="Transparent"
  Foreground="Black"/>
                        </Border>

                        <!-- ===== ФАЙЛЫ ===== -->
                        <Border Background="#EEEEEE"
                CornerRadius="10"
                Padding="10"
                Height="230"
                Margin="0 0 0 10">

                            <TreeView x:Name="VideoTreeView"
                      Background="Transparent"/>
                        </Border>

                        <!-- ===== КНОПКИ ===== -->
                        <Button Content="📁 Выбрать папку"
                Height="42"
                Margin="0 10 0 5"
                Style="{StaticResource FrostedButtonLight}"
                Click="ChooseFolderButton_Click"/>

                        <Button Content="🎞 Выбрать видео"
                Height="42"
                Style="{StaticResource FrostedButtonLight}"
                Click="ChooseVideoButton_Click"/>

                    </StackPanel>
                </Border>

                <!-- ===================== ЦЕНТРАЛЬНАЯ ===================== -->
                <Border Grid.Column="1"
Background="#3A3A3A"
CornerRadius="10"
Margin="0 0 20 0"
Padding="15">

                    <ScrollViewer VerticalScrollBarVisibility="Auto">

                        <StackPanel>

                            <!-- ================= СУБТИТРЫ ================= -->
                            <Expander Header="🎬 Субтитры"
  IsExpanded="True"
  Margin="0 0 0 10"
  Foreground="White">

                                <Border Background="#2A2A2A"
    CornerRadius="8"
    Padding="10"
    Margin="5">

                                    <StackPanel>

                                        <!-- КНОПКА ДОБАВЛЕНИЯ -->
                                        <Button Content="➕ Добавить шаблон субтитров"
            Height="36"
            Margin="0 0 0 10"
            Style="{StaticResource FrostedButtonLight}" 
                                Click="AddSubtitle_Click"/>

                                        <!-- СПИСОК ШАБЛОНОВ СУБТИТРОВ -->
                                        <ItemsControl ItemsSource="{Binding SubtitleSections}"
                          ItemTemplate="{StaticResource SectionTemplate}"/>
                                    </StackPanel>
                                </Border>
                            </Expander>

                            <!-- ================= ДОП. ИЗОБРАЖЕНИЯ ================= -->
                            <Expander Header="🖼 Дополнительные изображения"
                              Margin="0 0 0 10"
                              Foreground="White">

                                <Border Background="#2A2A2A"
                                CornerRadius="8"
                                Padding="10"
                                Margin="5">         

                                    <StackPanel>

                                        <Button Content="➕ Добавить изображение"
                                            Height="36"
                                            Margin="0 0 0 10"
                                            Style="{StaticResource FrostedButtonLight}"
                                            Click="AddImage_Click"/>

                                        <ItemsControl ItemsSource="{Binding ImageSections}"
                          ItemTemplate="{StaticResource SectionTemplate}"/>

                                    </StackPanel>

                                </Border>
                            </Expander>

                            <!-- ================= МОНТАЖ ВИДЕО ================= -->
                            <Expander Header="✂ Монтаж видео"
                                     Foreground="White">

                                <Border Background="#2A2A2A"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="5">     

                                    <StackPanel>

                                        <!-- Иконка -->
                                        <TextBlock Text="🚧"
               FontSize="48"
               HorizontalAlignment="Center"
               Margin="0 0 0 10"/>

                                        <!-- Заголовок -->
                                        <TextBlock Text="Раздел в разработке"
               FontSize="16"
               FontWeight="SemiBold"
               Foreground="White"
               HorizontalAlignment="Center"
               Margin="0 0 0 6"/>

                                        <!-- Описание -->
                                        <TextBlock Text="Пока здесь пусто. Вскоре будет обновлено."
               FontSize="13"
               Foreground="#AAAAAA"
               TextAlignment="Center"
               Width="260"/>

                                    </StackPanel>
                                </Border>
                            </Expander>
                            <!-- ================= ОБЩИЕ НАСТРОЙКИ ================= -->
                            <Expander Header="⚙️ Общие настройки"
          Margin="0 10 0 10"
          Foreground="White">

                                <Border Background="#2A2A2A"
            CornerRadius="8"
            Padding="10"
            Margin="5">
                                    <StackPanel>
                                        <TextBlock Text="Потоков ffmpeg" Foreground="White" FontSize="13"/>
                                        <TextBox x:Name="FfmpegThreadsBox"
                     Text="2"
                     Width="60"
                     HorizontalAlignment="Left"
                     Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Expander>

                            <!-- ================= КНОПКА ПРИМЕНИТЬ ================= -->
                            <Button Content="▶ Применить"
        Height="44"
        Width="200"
        Margin="0 50 0 6"
        Style="{StaticResource FrostedButtonLight}"
        Click="ApplyComposition_Click"/>
                        </StackPanel>

                    </ScrollViewer>
                </Border>

                <!-- ===================== ПРАВАЯ ПАНЕЛЬ (БЕЗ ИЗМЕНЕНИЙ) ===================== -->
                <Border Grid.Column="2"
        Background="#C2C2C2"
        CornerRadius="10"
        Padding="20">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Background="#E1E1E1"
                CornerRadius="12"
                Padding="20">
                            <StackPanel>
                                <TextBlock Text="Выбранное видео"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0 0 0 10"/>

                                <TextBlock x:Name="SelectedAspectText"
                           FontSize="16"/>

                                <TextBlock x:Name="SelectedVideoText"
                           FontSize="16"
                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1"
                Margin="0 20"
                Padding="7"
                Background="#F0F0F0"
                CornerRadius="12">

                            <Grid>
                                <!-- Видео -->
                                <Image x:Name="VideoPreviewImage"
                     Stretch="Uniform"/>
                                
                            
                            </Grid>
                        </Border>

                        
                    </Grid>
                </Border>

            </Grid>

            <!-- ===== ЭКРАН: СОЗДАНИЕ ВИДЕО ===== -->
            <Grid x:Name="CreateScreen"
      Margin="20"
      Visibility="Collapsed">

                <Border Background="#2A2A2A"
            CornerRadius="12"
            Padding="30">

                    <StackPanel>

                        <TextBlock Text="🧩 Создание видео"
                       FontSize="26"
                       Foreground="White"
                       Margin="0,0,0,20"/>

                        <!-- VIDEO PATH -->
                        <TextBlock Text="Видео файл" Foreground="White"/>
                        <DockPanel Margin="0,5,0,10">
                            <TextBox x:Name="VideoPathBox"
                         IsReadOnly="True"
                         DockPanel.Dock="Left"
                         Width="400"/>
                            <Button Content="Обзор..."
                        Margin="10,0,0,0"
                        Click="ChooseCreateVideo_Click"/>
                        </DockPanel>
                        <!-- OUTPUT DIR -->
                        <TextBlock Text="Папка вывода" Foreground="White"/>
                        <DockPanel Margin="0,5,0,10">
                            <TextBox x:Name="OutputDirBox"
             IsReadOnly="True"
             Width="400"
             DockPanel.Dock="Left"/>
                            <Button Content="Обзор..."
            Margin="10,0,0,0"
            Click="ChooseOutputDir_Click"/>
                        </DockPanel>

                        <!-- CLIP MODE -->
                        <TextBlock Text="Режим клипа" Foreground="White"/>
                        <ComboBox x:Name="ClipModeBox"
          Margin="0,5,0,10"
          Width="200">
                            <ComboBoxItem Content="blur"/>
                            <ComboBoxItem Content="letterbox"/>
                        </ComboBox>
                        <!-- SHORTS MODE -->
                        <TextBlock Text="Режим нарезки" Foreground="White"/>
                        <ComboBox x:Name="ShortsModeBox"
          Margin="0,5,0,10"
          Width="200"
          SelectionChanged="ShortsModeBox_SelectionChanged">
                            <ComboBoxItem Content="SimpleIntervalShorts" IsSelected="True"/>
                            <ComboBoxItem Content="TranscribeBasedShorts"/>
                        </ComboBox>
                        <TextBlock Text="Параллельных потоков" Foreground="White"/>
                        <TextBox x:Name="WorkersBox" Width="80" Text="4"
         HorizontalAlignment="Left" Margin="0,5,0,10"/>
                        <!-- ПАНЕЛЬ: SimpleIntervalShorts -->
                        <Border x:Name="SimplePanel"
                            BorderBrush="#555"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="⚙️ Параметры простой нарезки"
                                   Foreground="#AAA"
                                   FontSize="12"
                                   Margin="0,0,0,8"/>
                                <TextBlock Text="Интервал нарезки (сек)" Foreground="White"/>
                                <TextBox x:Name="IntervalBox" Width="120" Text="60" Margin="0,5,0,0"
                 HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <!-- ПАНЕЛЬ: TranscribeBasedShorts -->
                        <Border x:Name="TranscribePanel"
                            BorderBrush="#555"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,10"
                            Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="⚙️ Параметры нарезки по транскрипции"
                   Foreground="#AAA"
                   FontSize="12"
                   Margin="0,0,0,8"/>

                                <TextBlock Text="Whisper модель" Foreground="White"/>
                                <ComboBox x:Name="WhisperModelBox" Margin="0,5,0,10" Width="200">
                                    <ComboBoxItem Content="tiny"/>
                                    <ComboBoxItem Content="base"/>
                                    <ComboBoxItem Content="small"/>
                                    <ComboBoxItem Content="medium"/>
                                    <ComboBoxItem Content="large"/>
                                </ComboBox>

                                <TextBlock Text="Язык распознавания" Foreground="White"/>
                                <ComboBox x:Name="WhisperLanguageBox" Margin="0,5,0,10" Width="200">
                                    <ComboBoxItem Content="ru"/>
                                    <ComboBoxItem Content="en"/>
                                    <ComboBoxItem Content="auto"/>
                                </ComboBox>

                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Мин. длительность (сек)" Foreground="White"/>
                                        <TextBox x:Name="MinDurationBox" Width="120" Text="40"/>
                                    </StackPanel>
                                    <StackPanel Margin="20,0,0,0">
                                        <TextBlock Text="Макс. длительность (сек)" Foreground="White"/>
                                        <TextBox x:Name="MaxDurationBox" Width="120" Text="120"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <!-- APPLY -->
                        <Button Content="▶ Применить"
                    Width="200"
                    Height="40"
                    Background="#FF5C5C"
                    Foreground="White"
                    FontSize="16"
                    Click="ApplyCreate_Click"/>

                    </StackPanel>

                </Border>
            </Grid>

            <!-- ===== ЭКРАН: ЗАГРУЗКА ВИДЕО ===== -->
            <Grid x:Name="UploadScreen"
      Margin="20"
      Visibility="Collapsed">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="350"/>
                </Grid.ColumnDefinitions>

                <!-- ================= ЛЕВАЯ ПАНЕЛЬ: ВИДЕО ================= -->
                <Border Background="#E1E1E1"
        CornerRadius="12"
        Padding="16"
        Margin="0 0 20 0">

                    <StackPanel>

                        <TextBlock Text="Список видео"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0 0 0 10"/>

                        <!-- ✅ Список видео (исправленный) -->
                        <Border Background="#F0F0F0"
                CornerRadius="12"
                Padding="8"
                Margin="0 0 0 10">

                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20"
                                  ShadowDepth="0"
                                  Color="Black"
                                  Opacity="0.35"/>
                            </Border.Effect>
                            <ListBox x:Name="UploadVideoList"
         ItemsSource="{Binding UploadVideos}"
         Height="500"
         BorderThickness="0"
         Background="Transparent"
         ScrollViewer.VerticalScrollBarVisibility="Auto"
         SelectionMode="Extended"
         KeyDown="UploadVideoList_KeyDown">

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Иконка -->
                                            <Image Source="images/video_icon.png"
                       Width="32"
                       Height="32"
                       Margin="0,0,8,0"/>

                                            <!-- Имя файла -->
                                            <TextBlock Grid.Column="1"
                           Text="{Binding Converter={StaticResource FileNameConverter}}"
                           VerticalAlignment="Center"
                           FontSize="15"
                           Foreground="Black"
                           TextTrimming="CharacterEllipsis"/>

                                            <!-- ❌ Крестик -->
                                            <Button Grid.Column="2"
                        Content="✖"
                        Width="24"
                        Height="24"
                        Margin="8,0,0,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#888"
                        Cursor="Hand"
                        Click="RemoveUploadVideo_Click"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>

                            </ListBox>
                        </Border>

                        <!-- Кнопка -->
                        <Button Content="➕ Добавить видео"
        Height="36"
        Margin="0 10 0 0"
        Style="{StaticResource FrostedButtonDark}"
                      Click="AddUploadVideo_Click"/>

                    </StackPanel>
                </Border>

                <!-- ================= ЦЕНТР: РЕСУРСЫ ================= -->
                <Border Grid.Column="1"
        Background="#E1E1E1"
        CornerRadius="12"
        Padding="16"
        Margin="0 0 20 0">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- заголовок -->
                            <RowDefinition Height="*"/>
                            <!-- контент -->
                        </Grid.RowDefinitions>

                        <!-- Заголовок -->
                        <TextBlock
            Text="Ресурсы для выгрузки"
            FontSize="18"
            FontWeight="SemiBold"
            Foreground="Black"
            Margin="0 0 0 10"/>

                        <!-- Контейнер -->
                        <Border Grid.Row="1"
                Background="#F0F0F0"
                CornerRadius="10"
                Padding="12">

                            <DockPanel LastChildFill="True">

                                <!-- Кнопка сверху -->
                                <Button
                    DockPanel.Dock="Top"
                    Content="➕ Добавить паттерн выгрузки"
                    Height="36"
                    Margin="0 0 0 10"
                    Style="{StaticResource FrostedButtonDark}"
                    Click="AddResource_Click"/>

                                <!-- ✅ СКРОЛЛ РАБОТАЕТ -->
                                <ScrollViewer
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">

                                    <ItemsControl
                        ItemsSource="{Binding UploadResourceSections}"
                        ItemTemplate="{StaticResource SectionTemplate}"/>
                                </ScrollViewer>

                            </DockPanel>
                        </Border>

                    </Grid>
                </Border>


                <!-- ================= ПРАВАЯ ПАНЕЛЬ: АККАУНТЫ ================= -->
                <Border Grid.Column="2"
        Background="#E1E1E1"
        CornerRadius="12"
        Padding="16">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Заголовок -->
                        <StackPanel Grid.Row="0">
                            <TextBlock
                Text="Аккаунты"
                FontSize="18"
                FontWeight="SemiBold"
                Margin="0 0 0 10"/>

                            <Button
                Content="➕ Добавить аккаунт"
                Height="34"
                Margin="0 0 0 10"
                Style="{StaticResource FrostedButtonDark}"
                Click="AddGlobalAccount_Click"/>
                        </StackPanel>

                        <!-- ✅ СКРОЛЛ-КОНТЕЙНЕР -->
                        <ScrollViewer
            Grid.Row="1"
            VerticalScrollBarVisibility="Auto">

                            <ItemsControl
                ItemsSource="{Binding UploadAccounts}"
                ItemTemplate="{StaticResource UploadAccountManagerTemplate}"/>
                        </ScrollViewer>

                    </Grid>
                </Border>

            </Grid>

        </Grid>


    </Grid>



</Window>
    
    
